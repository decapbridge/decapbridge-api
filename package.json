{
  "name": "custom-extensions",
  "version": "1.0.0",
  "type": "module",
  "directus:extension": {
    "type": "bundle",
    "path": {
      "app": "extensions/custom-extensions/dist/app.js",
      "api": "extensions/custom-extensions/dist/api.js"
    },
    "entries": [
      {
        "type": "endpoint",
        "name": "health",
        "source": "src/health/index.ts"
      },
      {
        "type": "hook",
        "name": "config-tables",
        "source": "src/config-tables/index.ts"
      },
      {
        "type": "hook",
        "name": "env-settings",
        "source": "src/env-settings/index.ts"
      },
      {
        "type": "hook",
        "name": "user-signup",
        "source": "src/user-signup/index.ts"
      },
      {
        "type": "endpoint",
        "name": "sites",
        "source": "src/sites/index.ts"
      },
      {
        "type": "hook",
        "name": "encrypt-site-access-tokens",
        "source": "src/encrypt-site-access-tokens/index.ts"
      },
      {
        "type": "hook",
        "name": "free-limits",
        "source": "src/free-limits/index.ts"
      },
      {
        "type": "endpoint",
        "name": "sso-exchange-token",
        "source": "src/sso-exchange-token/index.ts"
      },
      {
        "type": "hook",
        "name": "stripe-raw-webhook",
        "source": "src/stripe/raw-webhook.ts"
      },
      {
        "type": "endpoint",
        "name": "stripe",
        "source": "src/stripe/index.ts"
      }
    ],
    "host": "^10.10.4"
  },
  "dependencies": {
    "directus": "^11.13.4",
    "stripe": "^20.0.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@directus/cli": "^9.14.3",
    "@directus/tsconfig": "^3.0.0",
    "@directus/types": "^13.2.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.17.1",
    "concurrently": "^9.2.0",
    "typescript": "^5.9.2"
  }
}
